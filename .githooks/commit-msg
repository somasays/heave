#!/usr/bin/env bash
# Commit-message policy. Project rule (see CLAUDE.md): commit messages must not
# attribute authorship to an AI assistant. This blocks the attribution patterns
# (co-author trailers, "generated by/with", the robot marker) rather than the
# bare vendor name — this project legitimately references Anthropic and routes
# `claude-*` model ids, so a blanket word ban would be self-defeating. The rule
# is about who the commit claims to be *from*, not what it talks about.
set -euo pipefail

msg_file="$1"

if grep -qiE \
  -e 'co-authored-by:[[:space:]]*(claude|anthropic)' \
  -e 'generated (with|by)[[:space:]]+\[?(claude|anthropic)' \
  -e 'claude code' \
  -e '🤖' \
  "$msg_file"; then
  cat >&2 <<'EOF'
commit-msg REJECTED: message must not attribute authorship to an AI assistant
(no "Co-Authored-By: Claude/Anthropic", no "Generated with/by Claude", no 🤖).
Referencing the Anthropic API or claude-* model ids is fine. See CLAUDE.md.
EOF
  exit 1
fi
